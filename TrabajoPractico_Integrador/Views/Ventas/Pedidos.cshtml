@model IEnumerable<TrabajoPractico_Integrador.Models.Venta>
@{
    ViewData["Title"] = "Pedidos";
}

<h2 class="mb-3">Pedidos Registrados</h2>

<!-- Buscador por nombre de usuario -->
<form method="get" class="row g-2 mb-4">
    <div class="col-auto">
        <input type="text" name="buscarUsuario" value="@ViewBag.FiltroUsuario"
               class="form-control" placeholder="Buscar por usuario..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Buscar</button>
        <a href="/Ventas/Pedidos" class="btn btn-outline-secondary">Limpiar</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No se encontraron pedidos.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Usuario</th>
                <th>Total</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pedido in Model)
            {
                <tr>
                    <td>@pedido.Id</td>
                    <td>@pedido.fecha.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@pedido.Cliente?.Nombre @pedido.Cliente?.Apellido</td>
                    <td>@pedido.Usuario?.NombreUsuario</td>
                    <td class="fw-bold">$@pedido.Total.ToString("N2")</td>
                    <td>
                        @if (pedido.Estado)
                        {
                            <span class="badge bg-success">Confirmado</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pendiente</span>
                        }
                    </td>
                    <td>
                        <a asp-action="DetallePedido" asp-route-id="@pedido.Id"
                           class="btn btn-sm btn-info">Ver Detalle</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}